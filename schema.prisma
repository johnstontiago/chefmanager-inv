generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Unidad {
  id          Int          @id @default(autoincrement())
  nombre      String
  direccion   String?
  responsable String?
  telefono    String?
  activo      Boolean      @default(true)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  usuarios    Usuario[]
  pedidos     Pedido[]
  inventario  Inventario[]
  movimientos Movimiento[]

  @@map("Unidad")
}

model Usuario {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  password    String       @map("password_hash")
  nombre      String
  rol         String       @default("viewer")
  pinCode     String?      @map("pin_code")
  unidadId    Int?         @map("unidad_id")
  unidad      Unidad?      @relation(fields: [unidadId], references: [id])
  activo      Boolean      @default(true)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  movimientos Movimiento[]

  @@map("Usuario")
}

model Categoria {
  id        Int        @id @default(autoincrement())
  nombre    String
  activo    Boolean    @default(true)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  productos Producto[]

  @@map("Categoria")
}

model Proveedor {
  id        Int        @id @default(autoincrement())
  nombre    String
  contacto  String?
  telefono  String?
  email     String?
  activo    Boolean    @default(true)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  productos Producto[]
  pedidos   Pedido[]

  @@map("Proveedor")
}

model Producto {
  id             Int          @id @default(autoincrement())
  nombre         String
  categoriaId    Int          @map("categoria_id")
  categoria      Categoria    @relation(fields: [categoriaId], references: [id])
  proveedorId    Int?         @map("proveedor_id")
  proveedor      Proveedor?   @relation(fields: [proveedorId], references: [id])
  unidadMedida   String       @default("kg") @map("unidad_medida")
  precioUnitario Decimal      @default(0) @map("precio_unitario")
  stockMinimo    Decimal      @default(0) @map("stock_minimo")
  activo         Boolean      @default(true)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  inventario     Inventario[]
  pedidoItems    PedidoItem[]
  movimientos    Movimiento[]

  @@map("Producto")
}

model Inventario {
  id             Int       @id @default(autoincrement())
  productoId     Int       @map("producto_id")
  producto       Producto  @relation(fields: [productoId], references: [id])
  unidadId       Int       @map("unidad_id")
  unidad         Unidad    @relation(fields: [unidadId], references: [id])
  cantidad       Decimal
  lote           String?
  fechaCaducidad DateTime? @map("fecha_caducidad")
  ubicacion      String?
  codigoUnico    String?   @map("codigo_unico")
  estado         String    @default("disponible")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("Inventario")
}

model Pedido {
  id          Int          @id @default(autoincrement())
  unidadId    Int          @map("unidad_id")
  unidad      Unidad       @relation(fields: [unidadId], references: [id])
  proveedorId Int?         @map("proveedor_id")
  proveedor   Proveedor?   @relation(fields: [proveedorId], references: [id])
  estado      String       @default("borrador")
  notas       String?
  total       Decimal      @default(0)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  items       PedidoItem[]

  @@map("Pedido")
}

model PedidoItem {
  id               Int       @id @default(autoincrement())
  pedidoId         Int       @map("pedido_id")
  pedido           Pedido    @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  productoId       Int       @map("producto_id")
  producto         Producto  @relation(fields: [productoId], references: [id])
  cantidad         Decimal
  precioUnitario   Decimal   @map("precio_unitario")
  subtotal         Decimal
  cantidadRecibida Decimal?  @map("cantidad_recibida")
  lote             String?
  fechaCaducidad   DateTime? @map("fecha_caducidad")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("PedidoItem")
}

model Movimiento {
  id         Int      @id @default(autoincrement())
  productoId Int      @map("producto_id")
  producto   Producto @relation(fields: [productoId], references: [id])
  unidadId   Int      @map("unidad_id")
  unidad     Unidad   @relation(fields: [unidadId], references: [id])
  usuarioId  Int      @map("usuario_id")
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  tipo       String
  cantidad   Decimal
  lote       String?
  notas      String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("Movimiento")
}
